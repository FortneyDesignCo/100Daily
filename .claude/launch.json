{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "100daily",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "require('http').createServer((q,r)=>{const fs=require('fs'),p=require('path'),f=p.join('.',q.url==='/'?'index.html':q.url),e=p.extname(f),t={'.html':'text/html','.js':'application/javascript','.css':'text/css','.png':'image/png','.svg':'image/svg+xml'};fs.readFile(f,(err,d)=>{if(err){r.writeHead(404);r.end()}else{r.writeHead(200,{'Content-Type':t[e]||'application/octet-stream'});r.end(d)}})}).listen(3000)"],
      "port": 3000
    }
  ]
}
